{
  "name": "opencode-sidebar-chat",
  "displayName": "Opencode Sidebar Chat",
  "description": "Professional AI coding assistant with multi-provider support, diff review, and brutalist design.",
  "version": "0.1.5",
  "publisher": "NovadaysTech",
  "author": {
    "name": "Emin"
  },
  "license": "MIT",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Education"
  ],
  "keywords": [
    "ai",
    "chat",
    "sidebar",
    "diff",
    "review",
    "opencode"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/emngny/opencode_sidebar"
  },
  "homepage": "https://github.com/emngny/opencode_sidebar#readme",
  "bugs": {
    "url": "https://github.com/emngny/opencode_sidebar/issues"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onView:opencode.sidebar"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "opencode",
          "title": "Opencode",
          "icon": "resources/icon.png"
        }
      ],
      "secondarySidebar": [
        {
          "id": "opencode",
          "title": "Opencode",
          "icon": "resources/icon.png"
        }
      ]
    },
    "views": {
      "opencode": [
        {
          "type": "webview",
          "id": "opencode.sidebar",
          "name": "Opencode",
          "icon": "resources/icon.png"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p tsconfig.extension.json && npm run build:webview",
    "build:webview": "node esbuild.config.js",
    "watch:extension": "tsc -watch -p tsconfig.extension.json",
    "watch:webview": "node esbuild.config.js --watch",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit": "npm audit"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/jest": "^30.0.0",
    "@types/marked": "^5.0.2",
    "@types/node": "^20.19.39",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "dompurify": "3.4.2",
    "marked": "18.0.3",
    "opencode-ai": "1.14.39",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  }
}
